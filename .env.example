# Local development — copy to .env and fill in your keys.
# Streamlit Cloud — add the same keys in App Settings → Secrets (TOML format).
# Get keys from https://build.nvidia.com

NVIDIA_MINIMAX_API_KEY=nvapi-your-minimax-key-here
NVIDIA_DEEPSEEK_API_KEY=nvapi-your-deepseek-key-here

# Or one shared key for both:
# NVIDIA_API_KEY=nvapi-your-shared-key-here
