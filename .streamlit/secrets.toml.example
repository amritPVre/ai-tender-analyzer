# Streamlit Cloud Secrets — paste into App Settings → Secrets (TOML format).
# Do NOT nest under [secrets] — use root-level keys exactly as shown.
# Get keys from https://build.nvidia.com (must start with nvapi-)

# Option A — separate keys (recommended if you have two)
NVIDIA_MINIMAX_API_KEY = "nvapi-your-minimax-key-here"
NVIDIA_DEEPSEEK_API_KEY = "nvapi-your-deepseek-key-here"

# Option B — one shared NVIDIA key for both models
# NVIDIA_API_KEY = "nvapi-your-shared-key-here"
